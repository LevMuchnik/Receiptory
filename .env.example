# All settings use RECEIPTORY_ prefix. See README.md for full setup instructions.

# --- LLM (required) ---
# RECEIPTORY_LLM_API_KEY=your-api-key-here
# RECEIPTORY_LLM_MODEL=gemini/gemini-3-flash-preview

# --- Auth ---
# RECEIPTORY_AUTH_USERNAME=admin
# RECEIPTORY_AUTH_PASSWORD=admin

# --- Telegram bot (get token from @BotFather) ---
# RECEIPTORY_TELEGRAM_BOT_TOKEN=123456:ABC-your-token
# RECEIPTORY_TELEGRAM_AUTHORIZED_USERS=["123456789"]  # your Telegram user ID, or [] for all

# --- Gmail (IMAP with App Password — no GCP project needed) ---
# RECEIPTORY_GMAIL_ADDRESS=your-receipts@gmail.com
# RECEIPTORY_GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx  # from myaccount.google.com/apppasswords (make sure to set up 2FA and create an app password for "Mail")
# RECEIPTORY_GMAIL_POLL_INTERVAL=300  # seconds  # seconds

# --- Dev mode (set to 1 when running backend + Vite dev server together) ---
# RECEIPTORY_DEV=1
